# CloudDesk — variáveis de ambiente
# Copie este arquivo para .env e preencha com os valores do seu projeto Supabase.
# NUNCA commite o arquivo .env — ele está no .gitignore.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard > Project Settings > API

VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ── Supabase Secrets (Edge Functions) ────────────────────────────────────────
# Configure via: supabase secrets set NOME=valor
# Ou via: Supabase Dashboard > Project Settings > Edge Functions > Secrets
#
# OPENAI_API_KEY=sk-...
# AIRTABLE_API_KEY=pat...
# AIRTABLE_BASE_ID=app...
# STRIPE_SECRET_KEY=rk_live_...    (restricted key, read-only — Fase 4)
# RESEND_API_KEY=re_...             (Fase 4 — canal email)
